@model IEnumerable<TaxiConnectSA.Models.DriverViewModel>
@{
    ViewData["Title"] = "Drivers";
    var all       = Model.ToList();
    var available = all.Where(d => d.IsAvailable).ToList();
    var onTrip    = all.Where(d => d.Status == "BUSY").ToList();
}

<div class="page-header">
    <h2>🚗 Drivers</h2>
    <div class="header-actions">
        <a href="/Drivers" class="btn btn-outline-secondary btn-sm">
            <i class="fa fa-rotate-right me-1"></i> Refresh
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (ViewBag.FirebaseError != null)
{
    <div class="alert alert-warning mt-3">
        <strong>Firebase not configured:</strong> @ViewBag.FirebaseError
    </div>
}

@* Summary tiles *@
<div class="stats">
    <div class="stat-card picked">
        <i class="fa fa-circle-check"></i>
        <h6>AVAILABLE AT RANK</h6>
        <h2>@available.Count</h2>
    </div>
    <div class="stat-card assigned">
        <i class="fa fa-car-side"></i>
        <h6>ON TRIP</h6>
        <h2>@onTrip.Count</h2>
    </div>
    <div class="stat-card completed">
        <i class="fa fa-users"></i>
        <h6>TOTAL DRIVERS</h6>
        <h2>@all.Count</h2>
    </div>
</div>

@* Debug info — shows actual Firestore field names *@
@if (all.Any() && all[0].RawFields.Any())
{
    <details class="mt-3">
        <summary class="text-muted small" style="cursor:pointer;">
            🔍 Firestore field debug (click to expand)
        </summary>
        <div class="alert alert-light border mt-1" style="font-size:11px;">
            <strong>Keys:</strong> <code>@string.Join(", ", all[0].RawFields.Keys)</code><br/>
            @foreach (var kv in all[0].RawFields)
            {
                <span class="me-3"><em>@kv.Key</em>: "<strong>@kv.Value</strong>"</span>
            }
        </div>
    </details>
}

@* All Drivers table *@
<div class="booking-card" style="margin-top: 20px;">
    <div class="table-header">
        <h4>All Drivers</h4>
        <div class="d-flex gap-2">
            <input type="text" id="driverSearch" class="search-box"
                   placeholder="Search driver or license plate..."
                   oninput="filterDrivers()" />
            <button class="btn btn-outline-secondary btn-sm" onclick="filterDrivers()">Search</button>
        </div>
    </div>

    @if (!all.Any())
    {
        <p class="text-muted text-center py-4">No drivers found in Firebase.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle" id="driversTable">
                <thead>
                    <tr>
                        <th>Driver</th>
                        <th>Vehicle</th>
                        <th>License Plate</th>
                        <th>Phone</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Action</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in all)
                    {
                        var initial        = d.Name.Length > 0 ? d.Name[0].ToString().ToUpper() : "?";
                        var displayName    = string.IsNullOrEmpty(d.Name)         ? d.GetField("name","driverName","fullName","displayName") : d.Name;
                        var displayVehicle = string.IsNullOrEmpty(d.Vehicle)      ? d.GetField("vehicle","vehicleType","carType","car","model") : d.Vehicle;
                        var displayPlate   = string.IsNullOrEmpty(d.LicensePlate) ? d.GetField("licensePlate","license_plate","taxiNumber","taxi","registration","plate") : d.LicensePlate;
                        var displayPhone   = string.IsNullOrEmpty(d.Phone)        ? d.GetField("phone","phoneNumber","mobile","contact","cellphone") : d.Phone;
                        var displayRating  = d.Rating > 0 ? d.Rating.ToString("F1") : d.GetField("rating","score");
                        var safeId         = d.Id;

                        <tr>
                            @* Driver *@
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="driver-avatar">@initial</div>
                                    <div>
                                        <strong>@(string.IsNullOrEmpty(displayName) ? "Unknown" : displayName)</strong>
                                        <br /><small class="text-muted" style="font-size:10px;">@d.Id[..8]</small>
                                    </div>
                                </div>
                            </td>
                            @* Vehicle *@
                            <td>@(string.IsNullOrEmpty(displayVehicle) ? "—" : displayVehicle)</td>
                            @* License Plate *@
                            <td>
                                @if (string.IsNullOrEmpty(displayPlate))
                                { <span class="text-muted">—</span> }
                                else
                                { <code>@displayPlate</code> }
                            </td>
                            @* Phone *@
                            <td>
                                @if (string.IsNullOrEmpty(displayPhone))
                                { <span class="text-muted">—</span> }
                                else
                                { <a href="tel:@displayPhone" class="text-decoration-none">@displayPhone</a> }
                            </td>
                            @* Rating *@
                            <td>
                                @if (!string.IsNullOrEmpty(displayRating) && displayRating != "0")
                                { <span>⭐ @displayRating</span> }
                                else
                                { <span class="text-muted">—</span> }
                            </td>
                            @* Status *@
                            <td><span class="@d.StatusCss">@d.StatusLabel</span></td>

                            @* Action dropdown *@
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle"
                                            type="button" data-bs-toggle="dropdown">
                                        Action
                                    </button>
                                    <ul class="dropdown-menu">
                                        @* ── Status actions ── *@
                                        <li><h6 class="dropdown-header">Status</h6></li>
                                        <li>
                                            <form method="post" action="/Drivers/SetStatus" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="driverId" value="@safeId" />
                                                <input type="hidden" name="newStatus" value="IDLE" />
                                                <button type="submit" class="dropdown-item">
                                                    <i class="fa fa-circle-check me-2 text-success"></i>Mark Available
                                                </button>
                                            </form>
                                        </li>
                                        <li>
                                            <form method="post" action="/Drivers/SetStatus" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="driverId" value="@safeId" />
                                                <input type="hidden" name="newStatus" value="BUSY" />
                                                <button type="submit" class="dropdown-item">
                                                    <i class="fa fa-car me-2 text-warning"></i>Mark On Trip
                                                </button>
                                            </form>
                                        </li>
                                        <li>
                                            <form method="post" action="/Drivers/SetStatus" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="driverId" value="@safeId" />
                                                <input type="hidden" name="newStatus" value="PENDING" />
                                                <button type="submit" class="dropdown-item">
                                                    <i class="fa fa-clock me-2 text-secondary"></i>Pending
                                                </button>
                                            </form>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>

                                        @* ── Booking actions ── *@
                                        <li><h6 class="dropdown-header">Booking</h6></li>
                                        <li>
                                            <button type="button" class="dropdown-item"
                                                    onclick="openAssignForDriver('@safeId', '@Html.Raw(displayName)')">
                                                <i class="fa fa-user-check me-2 text-primary"></i>Assign to Booking
                                            </button>
                                        </li>
                                        <li>
                                            <form method="post" action="/Drivers/SetStatus" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="driverId" value="@safeId" />
                                                <input type="hidden" name="newStatus" value="IDLE" />
                                                <button type="submit" class="dropdown-item">
                                                    <i class="fa fa-flag-checkered me-2 text-success"></i>Complete Trip
                                                </button>
                                            </form>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>

                                        @* ── Other ── *@
                                        <li>
                                            <a class="dropdown-item" href="tel:@displayPhone">
                                                <i class="fa fa-phone me-2 text-info"></i>Call Driver
                                            </a>
                                        </li>
                                        <li>
                                            <button type="button" class="dropdown-item"
                                                    onclick="openSaveModal('@safeId','@Html.Raw(displayName)','@Html.Raw(displayVehicle)','@Html.Raw(displayPlate)','@Html.Raw(displayPhone)','@d.StatusLabel')">
                                                <i class="fa fa-pen me-2 text-warning"></i>Edit
                                            </button>
                                        </li>
                                        <li>
                                            <form method="post" action="/Drivers/Delete" class="m-0"
                                                  onsubmit="return confirm('Delete @Html.Raw(displayName)?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="driverId" value="@safeId" />
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="fa fa-trash me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>

                            @* Save button (outside dropdown) *@
                            <td>
                                <button type="button" class="btn btn-warning btn-sm"
                                        onclick="openSaveModal('@safeId','@Html.Raw(displayName)','@Html.Raw(displayVehicle)','@Html.Raw(displayPlate)','@Html.Raw(displayPhone)','@d.StatusLabel')">
                                    <i class="fa fa-save me-1"></i> Save
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ── Save/Edit Driver Modal (saves to Firestore) ── *@
<div class="modal fade" id="saveDriverModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-save me-2"></i>Save Driver</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Drivers/Save">
                @Html.AntiForgeryToken()
                <input type="hidden" name="driverId" id="saveDriverId" />
                <div class="modal-body">
                    @* Read-only driver info — marshal cannot edit these *@
                    <div class="mb-3 p-3 rounded" style="background:#f8f9fa;">
                        <div class="mb-2 d-flex justify-content-between">
                            <span class="text-muted small">Driver Name</span>
                            <strong id="saveNameDisplay">—</strong>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span class="text-muted small">Vehicle</span>
                            <strong id="saveVehicleDisplay">—</strong>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span class="text-muted small">License Plate</span>
                            <strong id="savePlateDisplay">—</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">Phone Number</span>
                            <strong id="savePhoneDisplay">—</strong>
                        </div>
                    </div>
                    <small class="text-muted d-block mb-3">
                        <i class="fa fa-lock me-1"></i>Driver details are managed by the Association only.
                    </small>

                    @* Only Status is editable *@
                    <div class="mb-3">
                        <label class="form-label fw-bold">Status</label>
                        <select name="status" id="saveStatus" class="form-select">
                            <option value="IDLE">Available</option>
                            <option value="BUSY">On Trip</option>
                            <option value="PENDING">Pending</option>
                            <option value="COMPLETED">Completed</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="fa fa-save me-1"></i> Save to Database
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── Assign Driver to Booking Modal ── *@
@{
    var waitingBookings = ViewBag.WaitingBookings as List<TaxiConnectSA.Models.BookingModel> ?? new();
}
<div class="modal fade" id="assignDriverModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-user-check me-2"></i>Assign Driver to Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Bookings/Assign">
                @Html.AntiForgeryToken()
                <input type="hidden" name="driverId" id="assignDriverId" />
                <div class="modal-body">
                    <p class="mb-3">Assigning: <strong id="assignDriverName"></strong></p>

                    @if (!waitingBookings.Any())
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="fa fa-info-circle me-2"></i>
                            No waiting bookings at the moment. Create a booking first.
                        </div>
                    }
                    else
                    {
                        <label class="form-label fw-bold">Select Waiting Booking</label>
                        <select name="bookingId" class="form-select" required>
                            <option value="">-- Select a waiting booking --</option>
                            @foreach (var b in waitingBookings)
                            {
                                <option value="@b.Id">
                                    @b.ReferenceNo — @b.PickupLocation
                                    (@b.Passengers pax · @b.TimeAgo())
                                </option>
                            }
                        </select>
                        <small class="text-muted mt-1 d-block">
                            @waitingBookings.Count waiting booking(s) available
                        </small>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    @if (waitingBookings.Any())
                    {
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-check me-1"></i>Confirm Assignment
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterDrivers() {
            const q = document.getElementById("driverSearch").value.toLowerCase();
            document.querySelectorAll("#driversTable tbody tr").forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? "" : "none";
            });
        }

        function openSaveModal(id, name, vehicle, plate, phone, status) {
            document.getElementById("saveDriverId").value = id;

            // Read-only display fields
            document.getElementById("saveNameDisplay").textContent    = name    || "—";
            document.getElementById("saveVehicleDisplay").textContent = vehicle || "—";
            document.getElementById("savePlateDisplay").textContent   = plate   || "—";
            document.getElementById("savePhoneDisplay").textContent   = phone   || "—";

            // Only status is editable
            const statusMap = { "AVAILABLE": "IDLE", "ON TRIP": "BUSY", "PENDING": "PENDING", "COMPLETED": "COMPLETED" };
            const sel = document.getElementById("saveStatus");
            sel.value = statusMap[status?.toUpperCase()] || status || "IDLE";

            new bootstrap.Modal(document.getElementById("saveDriverModal")).show();
        }

        function openAssignForDriver(driverId, driverName) {
            document.getElementById("assignDriverId").value   = driverId;
            document.getElementById("assignDriverName").textContent = driverName;
            new bootstrap.Modal(document.getElementById("assignDriverModal")).show();
        }

        // Auto-refresh every 20 seconds so Firebase status changes appear
        setTimeout(() => location.reload(), 20000);
    </script>
}
