@model TaxiConnectSA.Models.CreateBookingViewModel
@{
    ViewData["Title"] = "New Booking";
}

<div class="page-header">
    <h2>📋 New Booking</h2>
    <a href="/" class="btn btn-outline-secondary">← Back to Dashboard</a>
</div>

<div class="booking-card" style="max-width: 600px; margin-top: 20px;">
    <h4 class="mb-4">Capture Passenger Details</h4>

    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="PassengerName" class="form-label fw-bold">Passenger Name</label>
            <input asp-for="PassengerName" class="form-control" placeholder="e.g. Sipho Dlamini" />
            <span asp-validation-for="PassengerName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PassengerPhone" class="form-label fw-bold">Phone Number</label>
            <input asp-for="PassengerPhone" class="form-control" placeholder="e.g. 0821234567" />
            <span asp-validation-for="PassengerPhone" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PickupLocation" class="form-label fw-bold">Pickup Location</label>
            <input asp-for="PickupLocation" class="form-control" placeholder="e.g. Madiba Street, Tembisa" />
            <span asp-validation-for="PickupLocation" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Passengers" class="form-label fw-bold">Number of Passengers</label>
            <input asp-for="Passengers" type="number" class="form-control" min="1" max="20" />
            <span asp-validation-for="Passengers" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Notes" class="form-label fw-bold">Notes <span class="text-muted fw-normal">(optional)</span></label>
            <textarea asp-for="Notes" class="form-control" rows="2"
                      placeholder="Any special instructions..."></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="new-booking">Create Booking</button>
            <a href="/" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
