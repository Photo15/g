@model IEnumerable<TaxiConnectSA.Models.BookingModel>
@{
    ViewData["Title"] = "Bookings";
    var drivers = ViewBag.AvailableDrivers as List<TaxiConnectSA.Models.DriverViewModel> ?? new();
}

<div class="page-header">
    <h2>📅 Bookings Management</h2>
    <a href="/Bookings/New" class="new-booking">+ New Booking</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (ViewBag.FirebaseError != null)
{
    <div class="alert alert-warning mt-3">
        <strong>Firebase not configured:</strong> @ViewBag.FirebaseError
    </div>
}

<div class="booking-card">
    <div class="table-header">
        <h4>All Bookings</h4>
        <input type="text" id="searchInput" class="search-box" placeholder="Search booking..." oninput="filterTable()" />
    </div>

    @if (!Model.Any())
    {
        <p class="text-muted text-center py-4">No bookings yet. <a href="/Bookings/New">Create one now</a>.</p>
    }
    else
    {
        <table class="table" id="bookingsTable">
            <thead>
                <tr>
                    <th>Ref No</th>
                    <th>Passenger</th>
                    <th>Pickup Location</th>
                    <th>Passengers</th>
                    <th>Status</th>
                    <th>Time</th>
                    <th>Driver</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    var statusClass = b.Status switch
                    {
                        "WAITING"   => "status-waiting",
                        "ASSIGNED"  => "status-assigned",
                        "PICKED UP" => "status-picked",
                        "COMPLETED" => "status-completed",
                        _           => "status-waiting"
                    };
                    <tr>
                        <td><strong>@b.ReferenceNo</strong></td>
                        <td>@b.PassengerName</td>
                        <td>@b.PickupLocation</td>
                        <td>@b.Passengers</td>
                        <td><span class="@statusClass">@b.Status</span></td>
                        <td>@b.TimeAgo()</td>
                        <td>@(string.IsNullOrEmpty(b.AssignedDriver) ? "—" : $"{b.AssignedDriver} ({b.TaxiNumber})")</td>
                        <td>
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary btn-sm dropdown-toggle"
                                        type="button" data-bs-toggle="dropdown">
                                    Action
                                </button>
                                <ul class="dropdown-menu">
                                    <li>
                                        <button type="button" class="dropdown-item"
                                                onclick="openAssignModal('@b.Id', '@Html.Raw(b.ReferenceNo)', '@Html.Raw(b.PickupLocation)', '@b.TimeAgo()')">
                                            <i class="fa fa-user-check me-2 text-primary"></i>Assign
                                        </button>
                                    </li>
                                    <li>
                                        <form method="post" action="/Bookings/UpdateStatus" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="bookingId" value="@b.Id" />
                                            <input type="hidden" name="newStatus" value="PICKED UP" />
                                            <button type="submit" class="dropdown-item">
                                                <i class="fa fa-car me-2 text-warning"></i>Pending
                                            </button>
                                        </form>
                                    </li>
                                    <li>
                                        <form method="post" action="/Bookings/UpdateStatus" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="bookingId" value="@b.Id" />
                                            <input type="hidden" name="newStatus" value="COMPLETED" />
                                            <button type="submit" class="dropdown-item">
                                                <i class="fa fa-circle-check me-2 text-success"></i>Complete
                                            </button>
                                        </form>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form method="post" action="/Bookings/Delete" class="m-0"
                                              onsubmit="return confirm('Delete @b.ReferenceNo?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="bookingId" value="@b.Id" />
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fa fa-trash me-2"></i>Delete
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* Assign Driver Modal *@
<div class="modal fade" id="assignModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Assign Driver</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Bookings/Assign">
                @Html.AntiForgeryToken()
                <input type="hidden" name="bookingId" id="modalBookingId" />
                <div class="modal-body">
                    <p class="mb-1"><strong>Booking:</strong> <span id="modalRef"></span></p>
                    <p class="mb-1"><strong>Pickup:</strong> <span id="modalLocation"></span></p>
                    <p class="mb-3"><strong>Time:</strong> <span id="modalTime"></span></p>
                    @if (!drivers.Any())
                    {
                        <div class="alert alert-warning mb-0">No available drivers at this time.</div>
                    }
                    else
                    {
                        <label class="form-label fw-bold">Select Driver</label>
                        <select name="driverId" class="form-select" required>
                            <option value="">-- Choose a driver --</option>
                            @foreach (var d in drivers)
                            {
                                <option value="@d.Id">@d.Name — @d.TaxiNumber</option>
                            }
                        </select>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    @if (drivers.Any())
                    {
                        <button type="submit" class="btn btn-primary">Confirm Assignment</button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAssignModal(bookingId, ref, location, time) {
            document.getElementById("modalBookingId").value = bookingId;
            document.getElementById("modalRef").textContent = ref;
            document.getElementById("modalLocation").textContent = location;
            document.getElementById("modalTime").textContent = time;
            new bootstrap.Modal(document.getElementById("assignModal")).show();
        }

        function filterTable() {
            const q = document.getElementById("searchInput").value.toLowerCase();
            document.querySelectorAll("#bookingsTable tbody tr").forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? "" : "none";
            });
        }
    </script>
}
