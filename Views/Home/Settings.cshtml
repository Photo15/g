@{
    ViewData["Title"] = "Settings";
}

<div class="page-header">
    <div>
        <h2>Settings</h2>
        <p class="text-muted">Manage app preferences, integrations, and security controls for TaxiConnect SA.</p>
    </div>
</div>

<div class="dashboard-card">
    <div class="row gy-4">
        <div class="col-12 col-xl-6">
            <div class="booking-card">
                <h4 class="mb-4">General Settings</h4>

                <form>
                    <div class="mb-3">
                        <label class="form-label">Association Name</label>
                        <input type="text" class="form-control" value="TaxiConnect SA" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Office Email</label>
                        <input type="email" class="form-control" value="support@taxiconnectsa.com" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contact Number</label>
                        <input type="tel" class="form-control" value="+27 11 123 4567" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Timezone</label>
                        <select class="form-select">
                            <option selected>South Africa Standard Time (SAST)</option>
                            <option>UTC</option>
                            <option>GMT+1</option>
                            <option>GMT+2</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-warning">Save General Settings</button>
                </form>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="booking-card">
                <h4 class="mb-4">Integration Settings</h4>

                <form>
                    <div class="mb-3">
                        <label class="form-label">Firebase Project ID</label>
                        <input type="text" class="form-control" placeholder="taxiconnectsa" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Service Account Path</label>
                        <input type="text" class="form-control" placeholder="firebase-key.json" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">SMS Provider</label>
                        <input type="text" class="form-control" value="Clickatell" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Support Portal URL</label>
                        <input type="url" class="form-control" placeholder="https://support.taxiconnectsa.com" />
                    </div>

                    <button type="submit" class="btn btn-warning">Save Integration Settings</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4 gy-4">
    <div class="col-12 col-lg-6">
        <div class="booking-card">
            <h4 class="mb-4">Security</h4>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="requireAuth" checked />
                <label class="form-check-label" for="requireAuth">Require login for all drivers</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="emailVerification" checked />
                <label class="form-check-label" for="emailVerification">Require email verification</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="enableAudit" />
                <label class="form-check-label" for="enableAudit">Enable audit logging</label>
            </div>

            <button type="button" class="btn btn-outline-secondary">Update Security</button>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="booking-card">
            <h4 class="mb-4">Notifications</h4>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="pushAlerts" checked />
                <label class="form-check-label" for="pushAlerts">Push alerts for new bookings</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="smsAlerts" />
                <label class="form-check-label" for="smsAlerts">SMS notifications for drivers</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="weeklySummary" checked />
                <label class="form-check-label" for="weeklySummary">Weekly summary email</label>
            </div>

            <button type="button" class="btn btn-outline-secondary">Update Notifications</button>
        </div>
    </div>
</div>