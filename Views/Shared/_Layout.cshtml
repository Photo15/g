<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - TaxiConnect SA</title>

    <!-- Firebase web config (set these in appsettings.json under Firebase:WebApiKey etc.) -->
    <meta name="fb-project-id"   content="taxiconnectsa-8dc27" />
    <meta name="fb-auth-domain"  content="taxiconnectsa-8dc27.firebaseapp.com" />
    <meta name="fb-api-key"      content="@(ViewBag.FirebaseWebApiKey ?? "")" />

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <!-- Dashboard CSS -->
    <link rel="stylesheet"
          href="~/css/dashboard.css"
          asp-append-version="true" />

    <!-- Project Styles -->
    <link rel="stylesheet"
          href="~/TaxiConnectSA.styles.css"
          asp-append-version="true" />
</head>

<body>

    <div class="dashboard-wrapper @(User.Identity?.IsAuthenticated == true ? string.Empty : "no-sidebar")">

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- Sidebar -->
            <partial name="_Sidebar" />
        }

        <!-- Main Content -->
        <div class="main-content">
            @RenderBody()
        </div>

    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    <!-- Firebase JS SDK (real-time listeners) -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
        import { getFirestore, collection, onSnapshot, query, orderBy, doc, updateDoc } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey:      document.querySelector('meta[name="fb-api-key"]')?.content      || "",
            authDomain:  document.querySelector('meta[name="fb-auth-domain"]')?.content  || "",
            projectId:   document.querySelector('meta[name="fb-project-id"]')?.content   || "taxiconnectsa-8dc27"
        };

        if (firebaseConfig.apiKey) {
            const app = initializeApp(firebaseConfig, "marshal-rt");
            const db  = getFirestore(app);

            window.__rtDb         = db;
            window.__rtCollection = collection;
            window.__rtOnSnapshot = onSnapshot;
            window.__rtQuery      = query;
            window.__rtOrderBy    = orderBy;
            window.__rtDoc        = doc;
            window.__rtUpdateDoc  = updateDoc;

            document.dispatchEvent(new Event("firestoreReady"));
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>